package build.testbase

import mill._, mill.scalalib._
import build.modules.{BaseModule, SharedDependencies}

object `package` extends BaseModule {
  def mvnDeps: T[Seq[Dep]] = SharedDependencies.logging ++ SharedDependencies.testing ++ SharedDependencies.database
  override def sources: T[Seq[PathRef]] = Task.Sources { "src/main/scala" }
  object test extends ScalaTester
}
