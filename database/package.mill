package build.database

import mill._, mill.scalalib._
import build.modules.{BaseModule, SharedDependencies}

object `package` extends BaseModule {
  def mvnDeps: T[Seq[Dep]] = SharedDependencies.logging ++ SharedDependencies.database ++ Seq(
    SharedDependencies.jsoup,
    SharedDependencies.scalaUri
  )
  override def moduleDeps = Seq(build.common, build.network)
  object test extends TestBase
}
